#!/bin/zsh
# Launches a tmux session with multiple windows.
#
# Usage: tmux-dev-env [session_name]

set -euo pipefail

session_name="${1:-dev}"

tmux new-session -d -s "${session_name}"
tmux rename-window -t "${session_name}" 'main'
tmux new-window -t "${session_name}" -n 'scratch' -d
tmux new-window -t "${session_name}" -n 'remote' -d

tmux attach -t "${session_name}"
